    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER NOT NULL,
    section TEXT NOT NULL,
    query_raw TEXT NOT NULL,
    query_normalized TEXT,
    query_effective TEXT,
    match_mode TEXT NOT NULL,
    results_count INTEGER NOT NULL DEFAULT 0,
    created_at INTEGER NOT NULL
);

CREATE INDEX idx_search_log_section_created_at
ON search_log(section, created_at);

CREATE INDEX idx_search_log_user_created_at
ON search_log(user_id, created_at);

CREATE INDEX idx_search_log_query_effective
ON search_log(query_effective);</sql><current_tab id="0"/></tab_sql></sqlb_project>
