BOT_TOKEN=replace-me
DATABASE_URL=sqlite+aiosqlite:////var/lib/rus-mus-srb-bot/bot.db
DATABASE_PATH=/var/lib/rus-mus-srb-bot/bot.db
LOG_DIR=/var/log/rus-mus-srb-bot
BACKUP_DIR=/var/backups/rus-mus-srb-bot
WEBAPP_BASE=https://example.org/rus_mus_srb_bot
RUS_MUS_SRB_BOT_SIGNING_KEY=replace-with-long-random-value
LOG_LEVEL=INFO
# Чат, куда web-admin временно загружает медиа для получения Telegram file_id.
CATEGORY_ADMIN_UPLOAD_CHAT_ID=519335258

# Нужны только если CATEGORY_ADMIN_HOST открывается не на loopback.
# CATEGORY_ADMIN_USER=choose-a-user
# CATEGORY_ADMIN_PASSWORD=replace-with-long-random-value
# Разрешённые DNS-имена админки через запятую (защита от DNS rebinding).
# CATEGORY_ADMIN_ALLOWED_HOSTS=admin.example.org
